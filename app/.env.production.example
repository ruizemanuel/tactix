# TACTIX production env (Celo mainnet). Set these as Vercel Project Environment Variables.
# NEVER commit real values — this .example only documents the keys.

# On-chain (Celo mainnet, chainId 42220)
NEXT_PUBLIC_CHAIN_ID=42220
NEXT_PUBLIC_TEGPOOL_ADDRESS=0x...                                   # the deployed mainnet TegPool
NEXT_PUBLIC_USDT_ADDRESS=0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e # Celo mainnet USDT (re-verify on Celoscan)

# Backend (server-only)
DATABASE_URL=postgres://user:pass@host/db   # Neon (production)
CRON_SECRET=choose-a-long-random-string      # Vercel Cron auto-sends it as the Bearer token
ORACLE_PRIVATE_KEY=0x...                      # the oracle signer (0x291DDf…); FUND with mainnet CELO for gas
RPC_URL=https://forno.celo.org                # mainnet RPC (or a dedicated provider if forno is flaky)

# Optional read-RPC overrides (client). Defaults: forno primary + drpc fallback.
# NEXT_PUBLIC_RPC_URL=https://forno.celo.org
# NEXT_PUBLIC_RPC_URL_FALLBACK=https://celo.drpc.org
# NEXT_PUBLIC_RPC_URL_SEPOLIA=
# Optional read-RPC fallback (server). Primary stays RPC_URL.
# RPC_URL_FALLBACK=https://celo.drpc.org

# C10 — PostHog product analytics (client-side, anonymous). The PROJECT key is
# publishable (write-only ingest) so it's safe in the client bundle, but keep the
# real value out of git — set it in Vercel env. Unset = analytics disabled (no-op).
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
